# Discord Bot Configuration
DISCORD_APP_ID=your_discord_app_id_here
PUBLIC_KEY=your_public_key_here

# LM Studio API (Local AI Model)
LM_STUDIO_API_URL=http://localhost:1234/v1/chat/completions
LM_STUDIO_API_KEY=
DEFAULT_MODEL=

# Context Window Configuration (optional, defaults to 4096 tokens)
# Set this based on your model's capabilities (e.g., 8192 for Llama-2-7b-chat, 32768 for Mistral-7B-Instruct v0.2)
CONTEXT_WINDOW_SIZE=4096

# Ollama API Configuration for Embeddings
OLLAMA_API_URL=http://localhost:11434/api
OLLAMA_EMBEDDING_MODEL=all-minilm

# Optional: Embedding API URL (if using external embedding server)
# EMBEDDING_API_URL=http://localhost:1234/v1/embeddings
